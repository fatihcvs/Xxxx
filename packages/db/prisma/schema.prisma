// Fameworld data model. Original schema; not affiliated with any existing game.
// Meters/attributes evolve in real time and are derived on read from anchors.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Accounts / Auth
// ---------------------------------------------------------------------------

enum UserRole {
  PLAYER
  ADMIN
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  locale       String    @default("en")
  role         UserRole  @default(PLAYER)
  vipUntil     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  characters Character[]

  @@index([email])
}

// ---------------------------------------------------------------------------
// World / Geography
// ---------------------------------------------------------------------------

model Country {
  id     String @id @default(cuid())
  name   String @unique
  code   String @unique // ISO-ish code
  cities City[]
}

model City {
  id        String @id @default(cuid())
  name      String
  countryId String
  country   Country @relation(fields: [countryId], references: [id])
  timezone  String  @default("UTC")
  reach     Int     @default(5000) // potential local audience
  // Geographic position; drives flight distance/cost/duration between cities.
  lat       Float   @default(0)
  lon       Float   @default(0)

  // Politics: current mayor and the tax rate they set (0..0.25).
  taxRate Float   @default(0)
  mayorId String?
  mayor   Character? @relation("Mayor", fields: [mayorId], references: [id])

  locales      Locale[]
  bornHere     Character[] @relation("BornCity")
  presentHere  Character[] @relation("CurrentCity")
  flyingHere   Character[] @relation("TravelingTo")
  bands        Band[]
  properties   Property[]
  businesses   Business[]
  elections    Election[]
  fanBases     FanBase[]
  news         NewsArticle[]

  @@unique([name, countryId])
}

enum LocaleType {
  CLUB
  RECORD_LABEL
  UNIVERSITY
  HOSPITAL
  SHOP
  BAR
  RESTAURANT
  APARTMENT
  STADIUM
  RADIO
  PARK
  AIRPORT
}

model Locale {
  id       String     @id @default(cuid())
  name     String
  type     LocaleType
  cityId   String
  city     City       @relation(fields: [cityId], references: [id])
  capacity Int        @default(100) // for venues

  jobs     Job[]
  present  Character[] @relation("CurrentLocale")
  concerts Concert[]
  courses  Course[]
  rentContracts RentContract[]

  @@index([cityId, type])
}

// ---------------------------------------------------------------------------
// Character
// ---------------------------------------------------------------------------

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Character {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  firstName String
  lastName  String
  gender    Gender
  isAlive   Boolean @default(true)

  // Anchored to in-game time.
  bornAtGame DateTime
  diedAtGame DateTime?

  cityBornId String
  cityBorn   City   @relation("BornCity", fields: [cityBornId], references: [id])

  currentCityId String
  currentCity   City   @relation("CurrentCity", fields: [currentCityId], references: [id])

  currentLocaleId String?
  currentLocale   Locale? @relation("CurrentLocale", fields: [currentLocaleId], references: [id])

  hospitalizedAt DateTime?
  // In-game time of the last aging/death roll (drives the aging sweep).
  lastAgedGameAt DateTime?

  // In-flight state: destination + real arrival time (cleared on arrival).
  travelingToCityId String?
  travelingTo       City?     @relation("TravelingTo", fields: [travelingToCityId], references: [id])
  travelArrivesAt   DateTime?

  // Family / heir line.
  parentId String?
  parent   Character?  @relation("Parentage", fields: [parentId], references: [id])
  children Character[] @relation("Parentage")

  // Economy / fame
  money     Int   @default(500)
  starValue Float @default(0)

  attributes CharacterAttribute[]
  meters     CharacterMeter[]
  skills     CharacterSkill[]

  memberships   BandMembership[]
  employment    Employment[]
  transactions  Transaction[]
  learningTasks LearningTask[]
  ownedBooks    OwnedBook[]
  rentContracts RentContract[]

  relationsFrom Relationship[] @relation("RelFrom")
  relationsTo   Relationship[] @relation("RelTo")
  messagesSent     Message[] @relation("MsgFrom")
  messagesReceived Message[] @relation("MsgTo")

  properties  Property[]
  businesses  Business[]
  mayoralCities City[]     @relation("Mayor")
  candidacies Candidacy[]
  votes       Vote[]
  stageRoles  CharacterStageRole[]
  achievements CharacterAchievement[]
  awards       Award[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([parentId])
  @@index([currentCityId])
}

model CharacterAttribute {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  attribute   String // matches game-engine Attribute union
  level       Int       @default(0)
  xp          Int       @default(0)

  @@unique([characterId, attribute])
}

enum MeterKind {
  MOOD
  HEALTH
  ENERGY
}

// Anchored meter: value at anchorAt (real time) + ratePerHour, derived on read.
model CharacterMeter {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  kind        MeterKind
  value       Float     @default(100)
  anchorAt    DateTime  @default(now())
  ratePerHour Float     @default(0)

  @@unique([characterId, kind])
}

// ---------------------------------------------------------------------------
// Skills / Education
// ---------------------------------------------------------------------------

model Skill {
  id       String @id @default(cuid())
  name     String @unique
  category String // matches game-engine SkillCategory
  maxLevel Int    @default(20)
  tier     Int    @default(1) // 1 = basic, 2+ = advanced

  // Prerequisite: must reach PREREQ_MIN_LEVEL in this skill before learning.
  prereqSkillId String?
  prereq        Skill?  @relation("SkillTree", fields: [prereqSkillId], references: [id])
  unlocks       Skill[] @relation("SkillTree")

  charSkills CharacterSkill[]
  books      Book[]

  @@index([category, tier])
}

model CharacterSkill {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  skillId     String
  skill       Skill     @relation(fields: [skillId], references: [id])
  level       Int       @default(0)

  @@unique([characterId, skillId])
}

model Book {
  id            String @id @default(cuid())
  title         String
  skillId       String
  skill         Skill  @relation(fields: [skillId], references: [id])
  price         Int    @default(100)
  maxTeachLevel Int    @default(5) // highest skill level this book can teach

  ownedBy OwnedBook[]
}

// A book a character owns and can study repeatedly (one level per study session).
model OwnedBook {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  bookId      String
  book        Book      @relation(fields: [bookId], references: [id])
  acquiredAt  DateTime  @default(now())

  @@unique([characterId, bookId])
}

// A university course: teaches a skill faster than self-study, for a fee.
model Course {
  id            String @id @default(cuid())
  localeId      String
  locale        Locale @relation(fields: [localeId], references: [id])
  skillId       String
  title         String
  fee           Int    @default(300)
  maxTeachLevel Int    @default(10)
  speedFactor   Float  @default(0.6) // learn time multiplier (<1 = faster)
}

// A scheduled skill-learning task that completes at a real timestamp.
enum LearningState {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model LearningTask {
  id          String        @id @default(cuid())
  characterId String
  character   Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  skillId     String
  fromLevel   Int
  toLevel     Int
  startedAt   DateTime      @default(now())
  finishesAt  DateTime
  state       LearningState @default(IN_PROGRESS)
  // Optional mentor teaching this task (faster than self-study).
  masterId    String?

  @@index([state, finishesAt])
}

// ---------------------------------------------------------------------------
// Jobs / Economy
// ---------------------------------------------------------------------------

model Job {
  id       String @id @default(cuid())
  title    String
  localeId String
  locale   Locale @relation(fields: [localeId], references: [id])
  salary   Int    @default(200) // weekly (paid on in-game Fridays)
  slots    Int    @default(3)

  employment Employment[]
}

model Employment {
  id             String    @id @default(cuid())
  characterId    String
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  jobId          String
  job            Job       @relation(fields: [jobId], references: [id])
  startedAt      DateTime  @default(now())
  active         Boolean   @default(true)
  // In-game date of the last salary payment; drives weekly (Friday) paydays.
  lastPaidGameAt DateTime?

  @@unique([characterId, jobId])
}

// Apartment rental. Rent is charged weekly; 4 missed weeks -> eviction.
model RentContract {
  id             String    @id @default(cuid())
  characterId    String
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  localeId       String
  locale         Locale    @relation(fields: [localeId], references: [id])
  weeklyRent     Int
  lastPaidGameAt DateTime
  missedWeeks    Int       @default(0)
  active         Boolean   @default(true)
  startedAt      DateTime  @default(now())

  @@index([active])
}

enum TxnType {
  SALARY
  PURCHASE
  RENT
  CONCERT
  OTHER
}

model Transaction {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  amount      Int // signed
  type        TxnType
  memo        String?
  createdAt   DateTime  @default(now())

  @@index([characterId, createdAt])
}

// ---------------------------------------------------------------------------
// Music
// ---------------------------------------------------------------------------

model Genre {
  id   String @id @default(cuid())
  name String @unique
  bands Band[]
}

model Band {
  id      String @id @default(cuid())
  name    String
  cityId  String
  city    City   @relation(fields: [cityId], references: [id])
  genreId String?
  genre   Genre? @relation(fields: [genreId], references: [id])
  fame    Float  @default(0)
  // In-game time of the last fame-decay check (release-freshness driven).
  lastFameDecayGameAt DateTime?
  // In-game time of the last press release (PR cooldown).
  lastPressGameAt DateTime?

  members  BandMembership[]
  songs    Song[]
  concerts Concert[]
  releases Release[]
  fanBases FanBase[]
  awards   Award[]

  createdAt DateTime @default(now())
}

// A band's fan base in a specific city (grown by concerts; boosts attendance).
model FanBase {
  id      String @id @default(cuid())
  bandId  String
  band    Band   @relation(fields: [bandId], references: [id], onDelete: Cascade)
  cityId  String
  city    City   @relation(fields: [cityId], references: [id])
  fans    Int    @default(0)

  @@unique([bandId, cityId])
  @@index([cityId])
}

model BandMembership {
  id          String    @id @default(cuid())
  bandId      String
  band        Band      @relation(fields: [bandId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  role        String // stage role
  share       Float     @default(0) // revenue share 0..1
  isLeader    Boolean   @default(false)

  @@unique([bandId, characterId])
}

model Song {
  id            String  @id @default(cuid())
  title         String
  bandId        String
  band          Band    @relation(fields: [bandId], references: [id], onDelete: Cascade)
  quality       Int     @default(0)
  lyricsQuality Int     @default(0)
  rehearsal     Int     @default(0) // jam level 0..100
  composedAt    DateTime @default(now())

  releaseTracks ReleaseTrack[]
}

enum ReleaseType {
  SINGLE
  ALBUM
}

// A recorded release (single or album) that accrues sales and charts over time.
model Release {
  id              String      @id @default(cuid())
  bandId          String
  band            Band        @relation(fields: [bandId], references: [id], onDelete: Cascade)
  title           String
  type            ReleaseType
  releasedAt      DateTime    @default(now())
  lastSalesGameAt DateTime // in-game time of the last weekly sales tick
  totalSales      Int         @default(0)
  chartScore      Float       @default(0) // rolling popularity used for ranking
  active          Boolean     @default(true)
  hasVideo        Boolean     @default(false)
  videoQuality    Int         @default(0) // 0..100; boosts sales & fame

  tracks ReleaseTrack[]

  @@index([active])
  @@index([chartScore])
}

model ReleaseTrack {
  id        String  @id @default(cuid())
  releaseId String
  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  songId    String
  song      Song    @relation(fields: [songId], references: [id])
  position  Int

  @@unique([releaseId, songId])
}

model Concert {
  id           String   @id @default(cuid())
  bandId       String
  band         Band     @relation(fields: [bandId], references: [id], onDelete: Cascade)
  localeId     String
  locale       Locale   @relation(fields: [localeId], references: [id])
  scheduledAt  DateTime
  ticketPrice  Int      @default(20)
  attendance   Int?
  revenue      Int?
  reviewScore  Int?
  played       Boolean  @default(false)

  @@index([played, scheduledAt])
}

// ---------------------------------------------------------------------------
// Social & Family (Faz 5)
// ---------------------------------------------------------------------------

enum RelationType {
  FRIEND
  PARTNER
  SPOUSE
  RIVAL
  FAMILY
}

model Relationship {
  id       String       @id @default(cuid())
  fromId   String
  from     Character    @relation("RelFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId     String
  to       Character    @relation("RelTo", fields: [toId], references: [id], onDelete: Cascade)
  type     RelationType @default(FRIEND)
  level    Int          @default(0) // -100..100 (affinity)
  updatedAt DateTime     @updatedAt

  @@unique([fromId, toId])
  @@index([toId])
}

model Message {
  id       String    @id @default(cuid())
  fromId   String
  from     Character @relation("MsgFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId     String
  to       Character @relation("MsgTo", fields: [toId], references: [id], onDelete: Cascade)
  body     String
  sentAt   DateTime  @default(now())
  readAt   DateTime?

  @@index([toId, sentAt])
}

// ---------------------------------------------------------------------------
// Real estate, business & politics (Faz 6)
// ---------------------------------------------------------------------------

enum PropertyKind {
  HOME   // owning a home removes weekly rent
  RENTAL // yields weekly rental income to the owner
}

model Property {
  id             String       @id @default(cuid())
  ownerId        String
  owner          Character    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cityId         String
  city           City         @relation(fields: [cityId], references: [id])
  name           String
  kind           PropertyKind
  purchasePrice  Int
  weeklyIncome   Int          @default(0) // for RENTAL
  lastPaidGameAt DateTime
  createdAt      DateTime     @default(now())

  @@index([ownerId])
}

model Business {
  id               String    @id @default(cuid())
  ownerId          String
  owner            Character @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cityId           String
  city             City      @relation(fields: [cityId], references: [id])
  name             String
  type             String
  value            Int
  baseWeeklyProfit Int
  lastPaidGameAt   DateTime
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())

  @@index([ownerId])
  @@index([active])
}

model Election {
  id          String      @id @default(cuid())
  cityId      String
  city        City        @relation(fields: [cityId], references: [id])
  opensAtGame DateTime
  closesAtGame DateTime
  resolved    Boolean     @default(false)
  winnerId    String?
  candidacies Candidacy[]
  votes       Vote[]

  @@index([cityId, resolved])
}

model Candidacy {
  id          String    @id @default(cuid())
  electionId  String
  election    Election  @relation(fields: [electionId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  votes       Int       @default(0)
  voteRecords Vote[]

  @@unique([electionId, characterId])
}

model Vote {
  id          String    @id @default(cuid())
  electionId  String
  election    Election  @relation(fields: [electionId], references: [id], onDelete: Cascade)
  voterId     String
  voter       Character @relation(fields: [voterId], references: [id], onDelete: Cascade)
  candidacyId String
  candidacy   Candidacy @relation(fields: [candidacyId], references: [id], onDelete: Cascade)

  @@unique([electionId, voterId])
}

// ---------------------------------------------------------------------------
// Music deepening (Faz 8)
// ---------------------------------------------------------------------------

enum StageRoleSlot {
  PRIMARY
  SECONDARY
}

// A character's chosen stage roles (primary weighted 80%, secondary 20%).
model CharacterStageRole {
  id          String        @id @default(cuid())
  characterId String
  character   Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  role        String // matches game-engine StageRole
  slot        StageRoleSlot

  @@unique([characterId, slot])
}

// ---------------------------------------------------------------------------
// Fame, media & achievements (Faz 10)
// ---------------------------------------------------------------------------

model Achievement {
  id          String @id @default(cuid())
  code        String @unique
  name        String
  description String
  category    String

  earnedBy CharacterAchievement[]
}

model CharacterAchievement {
  id            String      @id @default(cuid())
  characterId   String
  character     Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt      DateTime    @default(now())

  @@unique([characterId, achievementId])
  @@index([characterId])
}

enum NewsCategory {
  ELECTION
  CHARTS
  CONCERT
  OBITUARY
  PRESS_RELEASE
  AWARDS
}

// A newspaper article; cityId null = world desk (global news).
model NewsArticle {
  id        String       @id @default(cuid())
  cityId    String?
  city      City?        @relation(fields: [cityId], references: [id])
  category  NewsCategory
  headline  String
  body      String
  refId     String? // loose reference (release/band/character) used for dedupe
  createdAt DateTime     @default(now())

  @@index([createdAt])
  @@index([cityId, createdAt])
  @@index([category, createdAt])
}

// Annual music awards: one show per completed in-game year.
model AwardShow {
  id         String   @id @default(cuid())
  gameYear   Int      @unique
  heldAtGame DateTime

  awards Award[]
}

enum AwardCategory {
  BAND_OF_THE_YEAR
  ALBUM_OF_THE_YEAR
  SONG_OF_THE_YEAR
  ARTIST_OF_THE_YEAR
}

model Award {
  id          String        @id @default(cuid())
  showId      String
  show        AwardShow     @relation(fields: [showId], references: [id], onDelete: Cascade)
  category    AwardCategory
  bandId      String?
  band        Band?         @relation(fields: [bandId], references: [id])
  characterId String?
  character   Character?    @relation(fields: [characterId], references: [id])
  detail      String? // e.g. the winning release/song title

  @@unique([showId, category])
}
