# --- Database ---
DATABASE_URL="postgresql://fameworld:fameworld@localhost:5432/fameworld?schema=public"

# --- Redis (worker queues) ---
REDIS_URL="redis://localhost:6379"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
AUTH_URL="http://localhost:3000"

# --- World clock ---
# Real-world epoch (ISO) that maps to the in-game start date. Do not change after launch.
WORLD_EPOCH_REAL="2024-01-01T00:00:00.000Z"
# In-game start date shown to players at WORLD_EPOCH_REAL.
WORLD_EPOCH_GAME="2000-01-01T00:00:00.000Z"
# Real days per in-game year (Popmundo-style default: 56).
REAL_DAYS_PER_GAME_YEAR="56"
