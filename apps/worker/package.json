{
  "name": "@fameworld/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "once": "tsx src/index.ts --once",
    "seed-npc": "tsx src/index.ts --seed-npc",
    "typecheck": "tsc --noEmit",
    "build": "echo 'worker runs via tsx; no build step'"
  },
  "dependencies": {
    "@fameworld/db": "workspace:*",
    "@fameworld/game-engine": "workspace:*",
    "bullmq": "^5.34.10",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
